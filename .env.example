# Spring Cloud Config server URL (Vault-backed).
# Leave default if DNS resolves to your internal config-server.
CONFIG_SERVER_URL=https://j-srv-config.prod.payk8s.transcapital.com

# Active profile — determines which Vault path Config server reads.
# e.g. "test" → pay/app/asiapay/test, "prod" → pay/app/asiapay/prod
SPRING_PROFILES_ACTIVE=test

# Fallback only. Leave empty in environments where config-server serves A_TOKEN.
# Set this locally when running without config-server access.
A_TOKEN=
