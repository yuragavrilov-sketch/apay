# Active profile: local | test | prod
#   local — dev laptop / JUnit: no config-server, token from A_TOKEN or dev default
#   test  — deployed TEST env: A_TOKEN pulled from Spring Cloud Config / Vault
#   prod  — deployed PROD env: A_TOKEN pulled from Spring Cloud Config / Vault
SPRING_PROFILES_ACTIVE=prod

# Only for prod: URL of Spring Cloud Config server (Vault-backed).
CONFIG_SERVER_URL=https://j-srv-config.prod.payk8s.transcapital.com

# Only for local: fallback token when running without config-server access.
# Leave empty in prod — A_TOKEN comes from config-server.
A_TOKEN=
